# ── Runtime ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ── Storage ──────────────────────────────────────────────────────────────
# Set to "mongodb" to enable Mongo persistence; anything else => JSON file storage.
STORAGE_ADAPTER=mongodb
# Dev compose runs Mongo with no auth. Switch to
#   mongodb://USER:PASS@HOST:27017/banexcoin?authSource=admin
# when targeting an auth-enabled Mongo (compose.prod, Atlas, etc.).
MONGODB_URI=mongodb://localhost:27017/banexcoin?replicaSet=rs0&directConnection=true

# ── Auth (Clerk) ─────────────────────────────────────────────────────────
CLERK_SECRET_KEY=sk_test_replace-me
CLERK_AUTHORIZED_PARTIES=

# ── AI anomaly service ───────────────────────────────────────────────────
AI_API_URL=http://localhost:8081
AI_API_TIMEOUT_MS=15000

# ── Payout Oracle (USDT/BOB) ─────────────────────────────────────────────
# Live oracle endpoint consumed by BatchProcessService (legacy in-batch oracle).
ORACLE_URL=http://localhost:4000/oracle/current
ORACLE_FALLBACK_RATE=13.5

# Oracle module config (HTTP JSON provider).
PAYOUT_ORACLE_PROVIDER_URL=https://www.dolaresabolivianos.com/api/llm.json
PAYOUT_ORACLE_PROVIDER_ID=dolaresabolivianos-p2p-demo
PAYOUT_ORACLE_RATE_PATH=currency_pair.exchange_rate.average
PAYOUT_ORACLE_TIMESTAMP_PATH=metadata.updated_at
PAYOUT_ORACLE_SOURCE_PATH=metadata.source
PAYOUT_ORACLE_FRESHNESS_MINUTES=10
PAYOUT_ORACLE_MIN_RATE=5
PAYOUT_ORACLE_MAX_RATE=20
