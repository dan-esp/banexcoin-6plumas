# ── Runtime ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── Mongo (Prisma datasource: `env("MONGODB_URI")`) ──────────────────────
# Dev compose runs Mongo with no auth. Switch to
#   mongodb://USER:PASS@HOST:27017/banexcoin?authSource=admin
# when targeting an auth-enabled Mongo (compose.prod, Atlas, etc.).
MONGODB_URI=mongodb://localhost:27017/banexcoin?replicaSet=rs0&directConnection=true

# ── Auth (Clerk) ─────────────────────────────────────────────────────────
CLERK_SECRET_KEY=sk_test_replace-me
CLERK_AUTHORIZED_PARTIES=
