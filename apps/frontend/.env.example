# Copy to `.env.local` or `.env` in this folder (`apps/frontend`).
# Server actions read env from the Next.js app directory only (not the repo root).

# Browser → public API (read-only dashboard data)
NEXT_PUBLIC_API_URL=http://localhost:5000

# Clerk (see Clerk dashboard)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Server-side only: Next.js server actions → Nest private API (validate + batch process)
# Use 127.0.0.1 if `localhost` fails (IPv6 / WSL).
PRIVATE_API_URL=http://127.0.0.1:4000
