# Local development defaults — copy to .env and adjust as needed.
# None of these values should be used in production.

# ── Private API ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
# Storage backend: 'json' (file-based, no DB needed) or 'mongodb'
STORAGE_ADAPTER=json
MONGODB_URI=mongodb://localhost:27017/banexreintegra
# Rate Oracle — points to the public API oracle endpoint in local dev
ORACLE_URL=http://localhost:5000/oracle/current
ORACLE_FALLBACK_RATE=13.5

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=dev-secret-not-for-production
JWT_ISSUER=banexcoin
JWT_AUDIENCE=banexcoin-internal

# ── AI service (Isolation Forest) ─────────────────────────────────────────────
AI_PORT=8080
AI_MODEL_PATH=/app/data/model.joblib
AI_CONTAMINATION=auto
AI_N_ESTIMATORS=200
AI_RANDOM_STATE=42

# ── Frontend (Next.js build-time args) ────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_AI_URL=http://localhost:8081
# Server-only: Next.js server actions call the private API (must also exist in
# apps/frontend/.env or .env.local — Next does not load the repo root .env).
PRIVATE_API_URL=http://127.0.0.1:4000

# ── MongoDB infra (docker-compose only) ───────────────────────────────────────
MONGO_USER=banexcoin
MONGO_PASSWORD=banexcoin

# ── Host ports (docker-compose only) ──────────────────────────────────────────
FRONTEND_HOST_PORT=3000
PRIVATE_API_HOST_PORT=4000
PUBLIC_API_HOST_PORT=5000
AI_HOST_PORT=8081
MONGO_HOST_PORT=27017
