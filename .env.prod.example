# ── Frontend build-time (baked into Next bundle) ─────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace-me
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in

# ── MongoDB ───────────────────────────────────────────────────────────────
MONGO_USER=banexcoin
MONGO_PASSWORD=change-me-mongo
MONGO_HOST_PORT=27017

# ── Auth ─────────────────────────────────────────────────────────────────
CLERK_SECRET_KEY=sk_test_replace-me
CLERK_JWKS_URL=https://your-clerk-frontend-api.clerk.accounts.dev/.well-known/jwks.json
CLERK_AUTHORIZED_PARTIES=

# ── Payout Oracle (USDT/BOB) ─────────────────────────────────────────────
PAYOUT_ORACLE_PROVIDER_URL=https://www.dolaresabolivianos.com/api/llm.json
PAYOUT_ORACLE_PROVIDER_ID=dolaresabolivianos-p2p-demo
PAYOUT_ORACLE_RATE_PATH=currency_pair.exchange_rate.average
PAYOUT_ORACLE_TIMESTAMP_PATH=metadata.updated_at
PAYOUT_ORACLE_SOURCE_PATH=metadata.source
PAYOUT_ORACLE_FRESHNESS_MINUTES=10
PAYOUT_ORACLE_MIN_RATE=5
PAYOUT_ORACLE_MAX_RATE=20

# ── Database migrations ──────────────────────────────────────────────────
PRIVATE_API_RUN_MIGRATIONS=false
PRIVATE_API_MIGRATION_COMMAND=
PUBLIC_API_RUN_MIGRATIONS=false
PUBLIC_API_MIGRATION_COMMAND=
FRONTEND_RUN_MIGRATIONS=false
FRONTEND_MIGRATION_COMMAND=

# ── AI service (Isolation Forest) ────────────────────────────────────────
AI_CONTAMINATION=auto
AI_N_ESTIMATORS=200
AI_RANDOM_STATE=42
AI_HOST_PORT=8081

# ── App ports on host ────────────────────────────────────────────────────
FRONTEND_HOST_PORT=3000
PRIVATE_API_HOST_PORT=4000
PUBLIC_API_HOST_PORT=5000
